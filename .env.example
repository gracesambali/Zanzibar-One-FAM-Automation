# Copy this file to .env.local for local testing.
# In production, set these in Vercel: Project Settings → Environment Variables

# --- Airtable ---
AIRTABLE_API_KEY=            # Personal Access Token: airtable.com/create/tokens
AIRTABLE_BASE_ID=            # Found in Airtable API docs for your base (starts with "app")
AIRTABLE_TABLE_NAME=Components
AIRTABLE_LOG_TABLE_NAME=Alert Log
AIRTABLE_WORK_ORDERS_TABLE=Work Orders
AIRTABLE_RELOCATION_LOG_TABLE=Relocation Log

# --- API Integration (for ERP/SAP connections — see ERP-INTEGRATION-GUIDE.md) ---
API_INTEGRATION_KEY=          # long random string — give to client's IT team for automated access
API_INTEGRATION_ROLE=engineer # which role the API key acts as (controls cost data visibility)

# --- Resend (email) ---
RESEND_API_KEY=              # resend.com dashboard → API Keys
ALERT_FROM_EMAIL=            # must be a verified sender/domain in Resend, e.g. alerts@gracingventures.com
ALERT_FROM_NAME=Sali Asset Management   # the display name recipients see
ALERT_TO_EMAIL=               # comma-separated for multiple people, e.g. engineer@x.com,technician@x.com
HEARTBEAT_EMAIL=              # YOUR email — daily proof-of-life, separate from client alerts. Leave blank to reuse ALERT_TO_EMAIL.

# --- Beem Africa (SMS) ---
BEEM_API_KEY=                # beem.africa dashboard → profile → authentication information
BEEM_SECRET_KEY=
BEEM_SENDER_ID=INFO           # default sender ID, or your approved custom sender name
ALERT_TO_PHONE=               # comma-separated for multiple people, E.164 format, e.g. 255700000000,255710000000 (no + sign)

# --- Login (one username/password pair per role — all optional except at
# least one; leave any pair blank if that role doesn't exist yet for this client) ---
ENGINEER_USERNAME=
ENGINEER_PASSWORD=
TECHNICIAN_USERNAME=
TECHNICIAN_PASSWORD=
STOCK_KEEPER_USERNAME=
STOCK_KEEPER_PASSWORD=
OFFICE_ADMIN_USERNAME=
OFFICE_ADMIN_PASSWORD=
BUSINESS_OWNER_USERNAME=      # sees cost/depreciation + can manage users
BUSINESS_OWNER_PASSWORD=
SYSTEM_ADMIN_USERNAME=        # full access, same level as Business Owner
SYSTEM_ADMIN_PASSWORD=
SESSION_SECRET=               # any long random string — signs the login session, keep this private, never share it

# --- Public site URL (used to build the QR code links) ---
PUBLIC_SITE_URL=              # e.g. https://zanzibar-one-fam-automation.vercel.app (no trailing slash)

# --- Security ---
CRON_SECRET=                  # any random string — Vercel auto-sends this to authenticate cron calls
WEBHOOK_SECRET=                # any random string — you'll paste this into Airtable's webhook URL, see README
DEMO_TRIGGER_KEY=             # any random string you choose — used to manually fire a test alert during a pitch (separate from the real login, stays useful for quick demos)
