# Copy this file to .env.local for local testing.
# In production, set these in Vercel: Project Settings → Environment Variables

# --- Airtable ---
AIRTABLE_API_KEY=            # Personal Access Token: airtable.com/create/tokens
AIRTABLE_BASE_ID=            # Found in Airtable API docs for your base (starts with "app")
AIRTABLE_TABLE_NAME=Components

# --- Resend (email) ---
RESEND_API_KEY=              # resend.com dashboard → API Keys
ALERT_FROM_EMAIL=            # must be a verified sender/domain in Resend, e.g. alerts@gracingventures.com
ALERT_TO_EMAIL=               # where alerts should be sent for this pilot
HEARTBEAT_EMAIL=              # YOUR email — daily proof-of-life, separate from client alerts. Leave blank to reuse ALERT_TO_EMAIL.

# --- Beem Africa (SMS) ---
BEEM_API_KEY=                # beem.africa dashboard → profile → authentication information
BEEM_SECRET_KEY=
BEEM_SENDER_ID=INFO           # default sender ID, or your approved custom sender name
ALERT_TO_PHONE=               # E.164 format, e.g. 255700000000 (no + sign for Beem)

# --- Security ---
CRON_SECRET=                  # any random string — Vercel auto-sends this to authenticate cron calls
WEBHOOK_SECRET=                # any random string — you'll paste this into Airtable's webhook URL, see README
DEMO_TRIGGER_KEY=             # any random string you choose — used to manually fire a test alert during a pitch
