# Airtable
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=

# Sensor vendor (fill in once vendor is selected)
SENSOR_VENDOR_API_KEY=
SENSOR_VENDOR_API_BASE_URL=

# Shared secret to verify inbound sensor webhooks
SENSOR_WEBHOOK_SECRET=

# Alerting (TBD - email/SMS/WhatsApp provider)
ALERT_PROVIDER_API_KEY=

# Simulator (for testing without real hardware - see scripts/simulate-sensors.js)
SIMULATOR_TARGET_URL=http://localhost:3000/api/ingest-sensor-data
SIMULATE_INTERVAL_MS=10000
SIMULATE_ANOMALY_RATE=0.1
